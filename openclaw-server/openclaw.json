{
  "env": {
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "trusted-proxy",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": ["${MISSION_CONTROL_ORIGIN}"],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "list": [
      {
        "id": "JESSY",
        "default": true,
        "workspace": "/root/.openclaw/workspaces/JESSY"
      },
      {
        "id": "CLAWDIO",
        "workspace": "/root/.openclaw/workspaces/CLAWDIO"
      },
      {
        "id": "NEXUS",
        "workspace": "/root/.openclaw/workspaces/NEXUS"
      },
      {
        "id": "APEX",
        "workspace": "/root/.openclaw/workspaces/APEX"
      },
      {
        "id": "AXIOM",
        "workspace": "/root/.openclaw/workspaces/AXIOM"
      },
      {
        "id": "FORGE",
        "workspace": "/root/.openclaw/workspaces/FORGE"
      },
      {
        "id": "CLAUD",
        "workspace": "/root/.openclaw/workspaces/CLAUD"
      },
      {
        "id": "GEM",
        "workspace": "/root/.openclaw/workspaces/GEM"
      }
    ]
  }
}
